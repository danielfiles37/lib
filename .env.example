# AI Drama Studio 环境变量配置

# DeepSeek V4 Pro API Key (默认模型)
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Seedance 2.0 API Key
VITE_SEEDANCE_API_KEY=your_seedance_api_key_here

# Runway Gen-3 API Key
VITE_RUNWAY_API_KEY=your_runway_api_key_here

# Pika Labs API Key
VITE_PIKA_API_KEY=your_pika_api_key_here

# 自定义 API 配置
VITE_CUSTOM_API_KEY=your_custom_api_key_here
VITE_CUSTOM_API_URL=https://api.example.com/v1
