{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/hongniaoai/(.*)",
      "dest": "/api/proxy?path=hongniaoai/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
